{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integration": {
    "MessageSender": {
      "UseHttpFallback": false
    }
  },
  "OutboundMediaUpload": {
    "MaxImageBytes": 5242880,
    "MaxVideoBytes": 16777216,
    "MaxAudioBytes": 16777216,
    "MaxDocumentBytes": 104857600
  },
  "Redis": {
    "Database": 4,
    "SyncTimeoutMs": 15000,
    "AsyncTimeoutMs": 15000,
    "ConnectTimeoutMs": 15000
  },
  "Presence": {
    "SessionTtlSeconds": 120
  },
  "SlaReassignmentWorker": {
    "IntervalSeconds": 45,
    "FirstResponseScanIntervalSeconds": 5,
    "BatchSize": 50
  }
}
